{
  "name": "@pyodide-editable/html",
  "version": "0.1.0",
  "description": "Plain HTML helpers for pyodide_editable.",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chandraveshchaudhari/pyodide-editable.git",
    "directory": "packages/html"
  },
  "keywords": [
    "pyodide",
    "python",
    "browser",
    "html"
  ],
  "exports": {
    ".": "./src/index.mjs",
    "./browser.mjs": "./browser.mjs"
  },
  "files": [
    "README.md",
    "browser.mjs",
    "src"
  ],
  "dependencies": {
    "@pyodide-editable/core": "workspace:^"
  },
  "scripts": {
    "build": "node ../../scripts/check-package.mjs html",
    "check": "node ../../scripts/check-package.mjs html",
    "lint": "node ../../scripts/check-package.mjs html",
    "test": "node ../../scripts/check-package.mjs html"
  }
}
