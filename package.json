{
  "name": "pyodide_editable",
  "private": true,
  "version": "0.1.3",
  "description": "Editable Pyodide-backed Python cells for MyST, HTML, React, and Vue.",
  "type": "module",
  "license": "MIT",
  "author": "Chandravesh Chaudhari (https://github.com/chandraveshchaudhari)",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "corepack pnpm -r build",
    "check": "corepack pnpm -r check",
    "lint": "corepack pnpm -r lint",
    "test": "corepack pnpm -r test",
    "publish:packages": "corepack pnpm -r --filter './packages/*' publish --access public --no-git-checks"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chandraveshchaudhari/pyodide-editable.git"
  },
  "bugs": {
    "url": "https://github.com/chandraveshchaudhari/pyodide-editable/issues"
  },
  "homepage": "https://chandraveshchaudhari.github.io/pyodide-editable/",
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vue": "^3.5.13"
  }
}
